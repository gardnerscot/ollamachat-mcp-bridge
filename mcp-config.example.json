{
  "reminders": {
    "command": "npx",
    "args": ["-y", "reminders-mcp"],
    "env": {},
    "disabled": false
  },
  "notes": {
    "command": "npx",
    "args": ["-y", "apple-notes-mcp"],
    "env": {},
    "disabled": false
  },
  "mail": {
    "command": "uv",
    "args": [
      "run",
      "--directory",
      "/path/to/your/spark-mail-mcp",
      "spark-mail-mcp"
    ],
    "env": {},
    "disabled": true
  }
}
